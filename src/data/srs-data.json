{
  "use_cases": [
    {
      "id": "UC-001:",
      "title": "Create NFT",
      "actor": "Digital Artist",
      "precondition": "Artist has a digital artwork ready",
      "main_flow": [
        "1. Artist uploads artwork",
        "2. System generates NFT metadata",
        "3. Artist confirms details",
        "4. System mints NFT on Ethereum"
      ],
      "postcondition": "NFT is minted and available for sale",
      "linked_requirements": [
        "FR-001",
        "FR-002"
      ],
      "alternative_flows": [
        {
          "condition": "If artwork upload fails",
          "action": "System displays error message",
          "resulting_state": "Return to step 1"
        }
      ]
    },
    {
      "id": "UC-002:",
      "title": "Purchase NFT",
      "actor": "Art Collector",
      "precondition": "Collector has a funded MetaMask wallet",
      "main_flow": [
        "1. Collector selects NFT",
        "2. System displays NFT details",
        "3. Collector confirms purchase",
        "4. System processes transaction on Ethereum"
      ],
      "postcondition": "NFT ownership is transferred to collector",
      "linked_requirements": [
        "FR-003",
        "FR-004"
      ],
      "alternative_flows": [
        {
          "condition": "If transaction fails",
          "action": "System queues for retry",
          "resulting_state": "Return to step 3"
        }
      ]
    }
  ],
  "functional_requirements": [
    {
      "id": "FR-001:",
      "text": "[MUST] The system shall allow artists to upload digital artwork for NFT creation",
      "linked_requirements": [
        "DR-001"
      ]
    },
    {
      "id": "FR-002:",
      "text": "[MUST] The system shall mint NFTs on the Ethereum blockchain",
      "linked_requirements": [
        "DSS-001"
      ]
    },
    {
      "id": "FR-003:",
      "text": "[MUST] The system shall enable collectors to purchase NFTs using Ethereum",
      "linked_requirements": [
        "IR-001"
      ]
    },
    {
      "id": "FR-004:",
      "text": "[MUST] The system shall transfer NFT ownership upon successful purchase",
      "linked_requirements": [
        "DSS-002"
      ]
    },
    {
      "id": "FR-005:",
      "text": "[MUST] The system shall allow artists to list NFTs for sale on the marketplace",
      "linked_requirements": [
        "DR-002"
      ]
    },
    {
      "id": "FR-006:",
      "text": "[MUST] The system shall display NFT details including price and ownership history",
      "linked_requirements": [
        "DR-003"
      ]
    },
    {
      "id": "FR-007:",
      "text": "[SHOULD] The system shall support advanced auction features for NFTs",
